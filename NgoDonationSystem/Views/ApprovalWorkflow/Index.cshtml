@model IEnumerable<NgoDonationSystem.DTOs.Responses.ApprovalWorkflowResponse>

@{
    ViewData["Title"] = "Onay İş Akışları";
}

<div class="page-header">
    <h1><i class="fas fa-check-double me-2 text-muted"></i>@ViewData["Title"]</h1>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white py-3">
        <h6 class="mb-0 fw-semibold text-muted"><i class="fas fa-hourglass-half me-2"></i>Onay Bekleyen Kayıtlar</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>@Html.DisplayNameFor(m => m.EntityType)</th>
                        <th>@Html.DisplayNameFor(m => m.EntityId)</th>
                        <th>@Html.DisplayNameFor(m => m.RequestedByName)</th>
                        <th>@Html.DisplayNameFor(m => m.ApproverName)</th>
                        <th>@Html.DisplayNameFor(m => m.Status)</th>
                        <th>@Html.DisplayNameFor(m => m.Comments)</th>
                        <th class="text-center" style="width:200px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-muted">@item.Id</td>
                            <td>
                                @switch (item.EntityType)
                                {
                                    case "AidRequest": <span class="badge bg-info text-dark">Yardım Talebi</span> break;
                                    case "Donation": <span class="badge bg-primary">Bağış</span> break;
                                    default: <span class="badge bg-secondary">@item.EntityType</span> break;
                                }
                            </td>
                            <td><code>#@item.EntityId</code></td>
                            <td>@item.RequestedByName</td>
                            <td>@item.ApproverName</td>
                            <td>
                                @await Html.PartialAsync("_StatusBadge", null, new ViewDataDictionary(ViewData) { { "Status", item.Status } })
                            </td>
                            <td class="text-muted small" style="max-width:200px;">@item.Comments</td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-1">
                                    <form asp-action="Approve" asp-route-id="@item.Id" method="post">
                                        <button type="submit" class="btn btn-sm btn-success"><i class="fas fa-check me-1"></i>Onayla</button>
                                    </form>
                                    <form asp-action="Reject" asp-route-id="@item.Id" method="post">
                                        <input type="hidden" name="rejectReason" value="" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-times me-1"></i>Reddet</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
