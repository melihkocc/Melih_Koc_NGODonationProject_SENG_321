@model IEnumerable<NgoDonationSystem.DTOs.Responses.AidDistributionResponse>

@{
    ViewData["Title"] = "Yardım Dağıtımları";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1><i class="fas fa-truck-fast me-2 text-muted"></i>@ViewData["Title"]</h1>
    <a asp-action="Create" class="btn btn-sm px-3" style="background: var(--ngo-primary); color: #fff;">
        <i class="fas fa-plus me-1"></i> Yeni Dağıtım
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>@Html.DisplayNameFor(m => m.RequestedItems)</th>
                        <th>@Html.DisplayNameFor(m => m.BeneficiaryName)</th>
                        <th>@Html.DisplayNameFor(m => m.DeliveredByName)</th>
                        <th>@Html.DisplayNameFor(m => m.DeliveredAt)</th>
                        <th>@Html.DisplayNameFor(m => m.DeliveredNotes)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.RequestedItems</td>
                            <td>@item.BeneficiaryName</td>
                            <td>@item.DeliveredByName</td>
                            <td class="text-muted">@item.DeliveredAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-muted small">@item.DeliveredNotes</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
