@model NgoDonationSystem.DTOs.Responses.AidRequestResponse

@{
    ViewData["Title"] = "Talep Silme Onayı";
}

<div class="page-header">
    <h1><i class="fas fa-trash-alt me-2 text-danger"></i>@ViewData["Title"]</h1>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
        <div class="card shadow-sm border-danger">
            <div class="card-header py-3 bg-danger text-white text-center">
                <h5 class="mb-0"><i class="fas fa-exclamation-triangle me-2"></i>Bu talebi silmek istediğinize emin misiniz?</h5>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-warning py-2 mb-4 text-center">
                    <i class="fas fa-info-circle me-1"></i> Bu işlem geri alınamaz. Talep kalıcı olarak silinecektir.
                </div>

                <div class="border-bottom pb-3 mb-3">
                    <div class="text-muted small mb-1">@Html.DisplayNameFor(model => model.BeneficiaryName)</div>
                    <div class="fw-semibold fs-5">@Model.BeneficiaryName</div>
                </div>

                <div class="mb-4">
                    <div class="text-muted small mb-1">@Html.DisplayNameFor(model => model.RequestedItems)</div>
                    <div>@Model.RequestedItems</div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger flex-fill">
                            <i class="fas fa-trash-alt me-1"></i> Kalıcı Olarak Sil
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                            <i class="fas fa-times me-1"></i> Vazgeç
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
