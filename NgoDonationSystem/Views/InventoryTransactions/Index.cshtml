@model IEnumerable<NgoDonationSystem.DTOs.Responses.InventoryTransactionResponse>

@{
    ViewData["Title"] = "Stok Hareketleri";
}

<div class="page-header">
    <h1><i class="fas fa-arrow-right-arrow-left me-2 text-muted"></i>@ViewData["Title"]</h1>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>@Html.DisplayNameFor(m => m.ItemName)</th>
                        <th>@Html.DisplayNameFor(m => m.TransactionType)</th>
                        <th>@Html.DisplayNameFor(m => m.QuantityChanged)</th>
                        <th>@Html.DisplayNameFor(m => m.TransactionDate)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-muted">@item.Id</td>
                            <td class="fw-semibold">@item.ItemName</td>
                            <td>
                                @if (item.TransactionType == "Giriş")
                                { <span class="badge bg-success"><i class="fas fa-arrow-down me-1"></i>Giriş</span> }
                                else if (item.TransactionType == "Çıkış")
                                { <span class="badge bg-danger"><i class="fas fa-arrow-up me-1"></i>Çıkış</span> }
                                else
                                { <span class="badge bg-secondary">@item.TransactionType</span> }
                            </td>
                            <td>
                                @if (item.QuantityChanged > 0)
                                { <span class="text-success fw-semibold">+@item.QuantityChanged</span> }
                                else
                                { <span class="text-danger fw-semibold">@item.QuantityChanged</span> }
                            </td>
                            <td class="text-muted">@item.TransactionDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
