@model NgoDonationSystem.DTOs.Responses.InventoryItemResponse

@{
    ViewData["Title"] = "Ürün Detayları";
}

<div class="container-fluid px-4">
    <div class="row pt-4">
        <div class="col-md-5">
            <div class="card shadow border-0">
                <div class="card-header bg-info text-dark py-3">
                    <h4 class="m-0"><i class="fas fa-info-circle me-2"></i>@ViewData["Title"]</h4>
                </div>
                <div class="card-body p-4">
                    <div class="row border-bottom pb-2 mb-3">
                        <div class="col-sm-5 fw-bold text-muted">@Html.DisplayNameFor(model => model.ItemName)</div>
                        <div class="col-sm-7 text-primary fs-5">@Html.DisplayFor(model => model.ItemName)</div>
                    </div>
                    <div class="row border-bottom pb-2 mb-3">
                        <div class="col-sm-5 fw-bold text-muted">@Html.DisplayNameFor(model => model.CategoryName)</div>
                        <div class="col-sm-7"><span class="badge bg-secondary">@Model.CategoryName</span></div>
                    </div>
                    <div class="row border-bottom pb-2 mb-3">
                        <div class="col-sm-5 fw-bold text-muted">@Html.DisplayNameFor(model => model.Quantity)</div>
                        <div class="col-sm-7">
                            <span class="badge @(Model.Quantity > 0 ? "bg-success" : "bg-danger") fs-6">@Model.Quantity @Model.UnitType</span>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-sm-5 fw-bold text-muted">@Html.DisplayNameFor(model => model.WarehouseLocation)</div>
                        <div class="col-sm-7">@Html.DisplayFor(model => model.WarehouseLocation)</div>
                    </div>

                    <div class="d-flex gap-2 pt-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning shadow-sm flex-grow-1">
                            <i class="fas fa-edit me-1"></i> Düzenle
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary border shadow-sm">
                            <i class="fas fa-arrow-left me-1"></i> Geri
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white py-3">
                    <h4 class="m-0"><i class="fas fa-history me-2"></i>Stok Hareket Geçmişi</h4>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tarih</th>
                                    <th>Tür</th>
                                    <th class="text-end">Değişim</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Transactions != null && Model.Transactions.Any())
                                {
                                    @foreach (var t in Model.Transactions)
                                    {
                                        <tr>
                                            <td>@t.TransactionDate.ToString("g")</td>
                                            <td>
                                                <span class="badge @(t.TransactionType == "Giriş" ? "bg-success" : "bg-danger")">
                                                    @t.TransactionType
                                                </span>
                                            </td>
                                            <td class="text-end fw-bold @(t.QuantityChanged > 0 ? "text-success" : "text-danger")">
                                                @(t.QuantityChanged > 0 ? "+" : "")@t.QuantityChanged
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-4">Hareket bulunamadı.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
