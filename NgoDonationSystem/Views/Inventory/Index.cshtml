@model IEnumerable<NgoDonationSystem.DTOs.Responses.InventoryItemResponse>

@{
    ViewData["Title"] = "Envanter Ürünleri";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1><i class="fas fa-boxes-stacked me-2 text-muted"></i>@ViewData["Title"]</h1>
    <a asp-action="Create" class="btn btn-sm px-3" style="background: var(--ngo-primary); color: #fff;">
        <i class="fas fa-plus me-1"></i> Yeni Ürün
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>@Html.DisplayNameFor(m => m.ItemName)</th>
                        <th>@Html.DisplayNameFor(m => m.CategoryName)</th>
                        <th>@Html.DisplayNameFor(m => m.Quantity)</th>
                        <th>@Html.DisplayNameFor(m => m.UnitType)</th>
                        <th>@Html.DisplayNameFor(m => m.WarehouseLocation)</th>
                        <th class="text-center" style="width:180px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.ItemName</td>
                            <td><span class="badge bg-light text-dark border">@item.CategoryName</span></td>
                            <td>
                                @if (item.Quantity <= 5)
                                { <span class="badge bg-danger">@item.Quantity</span> }
                                else if (item.Quantity <= 20)
                                { <span class="badge bg-warning text-dark">@item.Quantity</span> }
                                else
                                { <span class="badge bg-success">@item.Quantity</span> }
                            </td>
                            <td>@item.UnitType</td>
                            <td class="text-muted">@item.WarehouseLocation</td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="AddStock" asp-route-id="@item.Id" class="btn btn-outline-success" title="Stok Ekle"><i class="fas fa-plus"></i></a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="Detay"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Düzenle"><i class="fas fa-pen"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Sil"><i class="fas fa-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
