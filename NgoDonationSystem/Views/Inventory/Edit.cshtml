@model NgoDonationSystem.DTOs.Requests.UpdateInventoryItemRequest

@{
    ViewData["Title"] = "Envanter Ürünü Düzenle";
}

<div class="row pt-4 px-4">
    <div class="col-md-6 offset-md-3">
        <div class="card shadow border-0">
            <div class="card-header bg-warning text-dark py-3">
                <h2 class="text-dark py-2 m-0 text-center">@ViewData["Title"]</h2>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="ItemName" class="form-label fw-bold"></label>
                        <input asp-for="ItemName" class="form-control" />
                        <span asp-validation-for="ItemName" class="text-danger"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CategoryId" class="form-label fw-bold"></label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                                <option value="">Kategori seçiniz...</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="UnitType" class="form-label fw-bold"></label>
                            <select asp-for="UnitType" class="form-select">
                                <option value="Adet">Adet</option>
                                <option value="Kg">Kg</option>
                                <option value="Litre">Litre</option>
                                <option value="Paket">Paket</option>
                                <option value="Kutu">Kutu</option>
                            </select>
                            <span asp-validation-for="UnitType" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Quantity" class="form-label fw-bold"></label>
                            <input asp-for="Quantity" class="form-control" type="number" min="0" />
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="WarehouseLocation" class="form-label fw-bold"></label>
                            <input asp-for="WarehouseLocation" class="form-control" />
                            <span asp-validation-for="WarehouseLocation" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row pt-2">
                        <div class="col-6">
                            <button type="submit" class="btn btn-primary form-control shadow-sm">Güncelle</button>
                        </div>
                        <div class="col-6">
                            <a asp-action="Index" class="btn btn-outline-secondary border form-control shadow-sm">Vazgeç</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
