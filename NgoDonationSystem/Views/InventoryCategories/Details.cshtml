@model NgoDonationSystem.DTOs.Responses.InventoryCategoryResponse

@{
    ViewData["Title"] = "Kategori Detayları";
}

<div class="container-fluid px-4">
    <div class="row pt-4">
        <div class="col-md-4">
            <div class="card shadow border-0 mb-4">
                <div class="card-header bg-success text-white py-3">
                    <h4 class="m-0"><i class="fas fa-tag me-2"></i>Kategori Bilgisi</h4>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4">
                        <label class="fw-bold text-muted d-block mb-1">@Html.DisplayNameFor(model => model.CategoryName)</label>
                        <div class="fs-4 text-primary fw-bold">@Model.CategoryName</div>
                    </div>
                    
                    <div class="d-flex gap-2 pt-2 border-top">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning shadow-sm flex-grow-1">
                            <i class="fas fa-edit me-1"></i> Düzenle
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary border shadow-sm">
                            <i class="fas fa-arrow-left me-1"></i> Geri Dön
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="card shadow border-0 bg-light">
                <div class="card-body p-4 text-center">
                    <div class="text-muted mb-2 small text-uppercase fw-bold">Toplam Ürün Sayısı</div>
                    <div class="display-5 fw-bold text-success">@Model.Items.Count</div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
                    <h4 class="m-0"><i class="fas fa-list me-2"></i>Bu Kategorideki Ürünler</h4>
                    <span class="badge bg-success rounded-pill">@Model.Items.Count Ürün</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Ürün Adı</th>
                                    <th>Miktar</th>
                                    <th>Depo Konumu</th>
                                    <th class="text-center">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Items != null && Model.Items.Any())
                                {
                                    @foreach (var item in Model.Items)
                                    {
                                        <tr>
                                            <td class="fw-bold text-primary">@item.ItemName</td>
                                            <td>
                                                <span class="badge @(item.Quantity > 0 ? "bg-info text-dark" : "bg-danger") px-3">
                                                    @item.Quantity @item.UnitType
                                                </span>
                                            </td>
                                            <td><small class="text-muted"><i class="fas fa-warehouse me-1"></i>@item.WarehouseLocation</small></td>
                                            <td class="text-center">
                                                <a asp-controller="Inventory" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                                    İncele
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="4" class="text-center text-muted py-5">Bu kategoriye henüz ürün eklenmemiş.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
