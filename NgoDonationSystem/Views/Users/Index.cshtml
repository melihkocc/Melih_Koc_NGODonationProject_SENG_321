@model IEnumerable<NgoDonationSystem.Models.User>

@{
    ViewData["Title"] = "Sistem Çalışanları / Kullanıcılar";
}

<div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4 mt-2">
    <h1 class="h3 m-0"><i class="fas fa-users-cog me-2 text-muted"></i>@ViewData["Title"]</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="fas fa-user-plus me-1"></i>Yeni Personel Ekle</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Ad Soyad</th>
                        <th>E-Posta</th>
                        <th>Rol / Yetki</th>
                        <th>Kayıt Tarihi</th>
                        <th>Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-medium">@item.FullName</td>
                            <td class="text-muted">@item.Email</td>
                            <td>
                                @if (item.Role?.RoleName == "FieldWorker")
                                {
                                    <span class="badge bg-success bg-opacity-75">FieldWorker (Saha Görevlisi / Dağıtıcı)</span>
                                }
                                else if (item.Role?.RoleName == "Admin")
                                {
                                    <span class="badge bg-danger">Admin (Sistem Yöneticisi)</span>
                                }
                                else if (item.Role?.RoleName == "WarehouseStaff")
                                {
                                    <span class="badge bg-info text-dark">WarehouseStaff (Depo Sorumlusu)</span>
                                }
                                else if (item.Role?.RoleName == "Accountant")
                                {
                                    <span class="badge bg-warning text-dark">Accountant (Muhasebeci)</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Role?.RoleName</span>
                                }
                            </td>
                            <td class="text-muted">@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i>Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"><i class="fas fa-times-circle me-1"></i>Pasif</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Sistemde henüz kayıtlı kullanıcı bulunmamaktadır.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
