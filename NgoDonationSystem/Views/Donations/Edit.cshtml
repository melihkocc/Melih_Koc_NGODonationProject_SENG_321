@model NgoDonationSystem.DTOs.Requests.UpdateDonationRequest

@{
    ViewData["Title"] = "Bağış Düzenle";
}

<div class="page-header">
    <h1><i class="fas fa-pen me-2 text-muted"></i>@ViewData["Title"]</h1>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
        <div class="card shadow-sm">
            <div class="card-header py-3 bg-warning bg-opacity-75 text-dark">
                <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Bağış Bilgilerini Güncelle</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="DonorId" class="form-label fw-semibold"></label>
                        <select asp-for="DonorId" class="form-select" asp-items="ViewBag.DonorId">
                            <option value="">— Bağışçı Seçiniz —</option>
                        </select>
                        <span asp-validation-for="DonorId" class="text-danger small"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Amount" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                                <span class="input-group-text">₺</span>
                            </div>
                            <span asp-validation-for="Amount" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Currency" class="form-label fw-semibold"></label>
                            <select asp-for="Currency" class="form-select" readonly>
                                <option value="TRY" selected>TRY — Türk Lirası</option>
                            </select>
                            <span asp-validation-for="Currency" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="DonationType" class="form-label fw-semibold"></label>
                            <select asp-for="DonationType" class="form-select">
                                <option value="Online">Online</option>
                                <option value="Havale/EFT">Havale / EFT</option>
                                <option value="Elden">Elden</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label fw-semibold"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Pending">Beklemede</option>
                                <option value="Completed">Tamamlandı</option>
                                <option value="Cancelled">İptal Edildi</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-warning flex-fill">
                            <i class="fas fa-save me-1"></i> Güncelle
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                            <i class="fas fa-times me-1"></i> Vazgeç
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
