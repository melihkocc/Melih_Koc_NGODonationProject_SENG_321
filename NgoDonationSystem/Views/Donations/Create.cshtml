@model NgoDonationSystem.DTOs.Requests.CreateDonationRequest

@{
    ViewData["Title"] = "Yeni Bağış Ekle";
}

<div class="page-header">
    <h1><i class="fas fa-hand-holding-usd me-2 text-muted"></i>@ViewData["Title"]</h1>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
        <div class="card shadow-sm">
            <div class="card-header py-3" style="background: var(--ngo-primary); color: #fff;">
                <h5 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Bağış Bilgileri</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    @if (!User.IsInRole("Donor"))
                    {
                        <div class="mb-3">
                            <label asp-for="DonorId" class="form-label fw-semibold"></label>
                            <select asp-for="DonorId" class="form-select" asp-items="ViewBag.DonorId">
                                <option value="">— Bağışçı Seçiniz —</option>
                            </select>
                            <span asp-validation-for="DonorId" class="text-danger small"></span>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" asp-for="DonorId" value="0" />
                    }

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Amount" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="Amount" class="form-control" type="number" step="0.01" placeholder="0.00" />
                                <span class="input-group-text">₺</span>
                            </div>
                            <span asp-validation-for="Amount" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Currency" class="form-label fw-semibold"></label>
                            <select asp-for="Currency" class="form-select" readonly>
                                <option value="TRY" selected>TRY — Türk Lirası</option>
                            </select>
                            <span asp-validation-for="Currency" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="DonationType" class="form-label fw-semibold"></label>
                        <select asp-for="DonationType" class="form-select">
                            <option value="Online">Online</option>
                            <option value="Havale/EFT">Havale / EFT</option>
                            <option value="Elden">Elden</option>
                        </select>
                        <span asp-validation-for="DonationType" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn flex-fill" style="background: var(--ngo-primary); color: #fff;">
                            <i class="fas fa-save me-1"></i> Kaydet
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                            <i class="fas fa-times me-1"></i> Vazgeç
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
