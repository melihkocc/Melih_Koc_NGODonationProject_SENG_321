@model IEnumerable<NgoDonationSystem.DTOs.Responses.DonationResponse>

@{
    ViewData["Title"] = "Bağış Listesi";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1><i class="fas fa-hand-holding-usd me-2 text-muted"></i>@ViewData["Title"]</h1>
    <a asp-action="Create" class="btn btn-sm px-3" style="background: var(--ngo-primary); color: #fff;">
        <i class="fas fa-plus me-1"></i> Yeni Bağış
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>@Html.DisplayNameFor(m => m.DonorName)</th>
                        <th>@Html.DisplayNameFor(m => m.Amount)</th>
                        <th>@Html.DisplayNameFor(m => m.Currency)</th>
                        <th>@Html.DisplayNameFor(m => m.DonationType)</th>
                        <th>@Html.DisplayNameFor(m => m.Status)</th>
                        <th>@Html.DisplayNameFor(m => m.CreatedByName)</th>
                        <th>@Html.DisplayNameFor(m => m.CreatedAt)</th>
                        <th class="text-center" style="width:140px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.DonorName</td>
                            <td class="fw-semibold">@item.Amount.ToString("N2") ₺</td>
                            <td>@item.Currency</td>
                            <td>
                                @switch (item.DonationType)
                                {
                                    case "Cash": <span class="badge bg-info text-dark">Nakdi</span> break;
                                    case "InKind": <span class="badge bg-secondary">Ayni</span> break;
                                    default: <span class="badge bg-light text-dark border">@item.DonationType</span> break;
                                }
                            </td>
                            <td>
                                @await Html.PartialAsync("_StatusBadge", null, new ViewDataDictionary(ViewData) { { "Status", item.Status } })
                            </td>
                            <td>@item.CreatedByName</td>
                            <td class="text-muted">@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Düzenle"><i class="fas fa-pen"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
