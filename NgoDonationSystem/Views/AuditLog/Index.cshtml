@model IEnumerable<NgoDonationSystem.DTOs.Responses.AuditLogResponse>

@{
    ViewData["Title"] = "Denetim Günlüğü";
}

<div class="page-header">
    <h1><i class="fas fa-scroll me-2 text-muted"></i>@ViewData["Title"]</h1>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0 align-middle" style="font-size:.85rem;">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>@Html.DisplayNameFor(m => m.TableName)</th>
                        <th>@Html.DisplayNameFor(m => m.Action)</th>
                        <th>@Html.DisplayNameFor(m => m.UserName)</th>
                        <th>@Html.DisplayNameFor(m => m.Timestamp)</th>
                        <th class="text-center" style="width:80px;">Detay</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-muted">@item.Id</td>
                            <td><code>@item.TableName</code></td>
                            <td>
                                @switch (item.Action)
                                {
                                    case "INSERT": <span class="badge bg-success">Ekleme</span> break;
                                    case "UPDATE": <span class="badge bg-warning text-dark">Güncelleme</span> break;
                                    case "DELETE": <span class="badge bg-danger">Silme</span> break;
                                    default: <span class="badge bg-secondary">@item.Action</span> break;
                                }
                            </td>
                            <td>@item.UserName</td>
                            <td class="text-muted">@item.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info"><i class="fas fa-eye"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
