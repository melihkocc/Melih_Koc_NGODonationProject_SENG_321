@model IEnumerable<NgoDonationSystem.Models.Document>

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2>Doküman Yönetimi</h2>
        </div>
        <div class="col-md-6 text-md-end">
            <a asp-action="Create" class="btn btn-primary">Yeni Doküman Yükle</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Dosya Adı</th>
                        <th>Dosya Türü</th>
                        <th>Yükleme Tarihi</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.FileName</td>
                                <td>@item.FileType</td>
                                <td>@item.UploadedDate.ToLocalTime().ToString("g")</td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a asp-action="Download" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success" title="İndir">
                                            <i class="fas fa-download me-1"></i> İndir
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="İncele">
                                            <i class="fas fa-info-circle me-1"></i> İncele
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Sil">
                                            <i class="fas fa-trash me-1"></i> Sil
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">Henüz doküman yüklenmemiş.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
