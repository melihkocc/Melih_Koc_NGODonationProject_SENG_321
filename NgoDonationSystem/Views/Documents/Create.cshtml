<div class="row mt-4">
    <div class="col-md-6 offset-md-3">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Yeni Doküman Yükle</h4>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="file" class="form-label">Dosya Seçin</label>
                        <input type="file" name="file" class="form-control" required />
                        <div class="form-text text-muted">
                            Yüklenecek dosyaların güvenliği için sistem tarafından otomatik olarak adlandırılacağını unutmayın.
                        </div>
                    </div>
                    
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">İptal</a>
                        <button type="submit" class="btn btn-success">Yüklemeyi Başlat</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
