@model NgoDonationSystem.Models.Document

@{
    ViewData["Title"] = "Belgeyi Sil";
}

<div class="row pt-4 px-4">
    <div class="col-md-6 offset-md-3">
        <div class="card shadow border-0 border-danger">
            <div class="card-header bg-danger text-white py-3 text-center">
                <h2 class="text-white py-2 m-0"><i class="fas fa-exclamation-triangle me-2"></i>@ViewData["Title"]</h2>
            </div>
            <div class="card-body p-4 text-center">
                <h4 class="text-danger mb-4">Bu belgeyi silmek istediğinizden emin misiniz?</h4>
                
                <div class="alert alert-warning text-start mb-4">
                    <i class="fas fa-info-circle me-1"></i> Bu işlem geri alınamaz ve dosya sunucudan tamamen silinecektir.
                </div>

                <div class="mb-4 text-start">
                    <div class="row border-bottom pb-2 mb-3">
                        <div class="col-4 fw-bold text-muted">Belge Adı</div>
                        <div class="col-8">@Model.FileName</div>
                    </div>
                    <div class="row border-bottom pb-2 mb-3">
                        <div class="col-4 fw-bold text-muted">Yüklenme Tarihi</div>
                        <div class="col-8 text-secondary">@Model.UploadedDate.ToLocalTime().ToString("g")</div>
                    </div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="row pt-2 justify-content-center">
                        <div class="col-6">
                            <button type="submit" class="btn btn-danger form-control shadow-sm">
                                <i class="fas fa-trash-alt me-1"></i> Kalıcı Olarak Sil
                            </button>
                        </div>
                        <div class="col-6">
                            <a asp-action="Index" class="btn btn-outline-secondary border form-control shadow-sm">
                                <i class="fas fa-times me-1"></i> Vazgeç
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
